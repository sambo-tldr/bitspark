{
  "name": "bitspark-tests",
  "version": "1.0.0",
  "description": "Run unit tests on this project.",
  "type": "module",
  "private": true,
  "scripts": {
    "test": "vitest run",
    "test:report": "vitest run -- --coverage --costs",
    "test:watch": "chokidar \"tests/**/*.ts\" \"contracts/**/*.clar\" -c \"npm run test:report\"",
    "testnet": "npx ts-node --esm scripts/testnet-test.ts",
    "testnet:stats": "npx ts-node --esm scripts/testnet-test.ts stats",
    "testnet:campaign": "npx ts-node --esm scripts/testnet-test.ts campaign",
    "testnet:full": "npx ts-node --esm scripts/testnet-full.ts"
  },
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@stacks/clarinet-sdk": "^3.9.0",
    "@stacks/network": "^7.0.0",
    "@stacks/transactions": "^7.2.0",
    "@types/node": "^24.4.0",
    "chokidar-cli": "^3.0.0",
    "ts-node": "^10.9.2",
    "vitest": "^4.0.7",
    "vitest-environment-clarinet": "^3.0.0"
  },
  "devDependencies": {
    "@stacks/wallet-sdk": "^7.2.0"
  }
}
